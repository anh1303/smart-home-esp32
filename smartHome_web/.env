# SmartHome ESP32 - Node.js Server Environment
# Copy this file to your server project root as `.env`
# IMPORTANT: Do not commit `.env` or Firebase service account JSON to GitHub.

PORT=3000
NODE_ENV=development

# Firebase Admin SDK service account JSON path
# Recommended project structure:
# server/
#   config/
#     firebase-key.json
#     firebase.js
#   .env
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase_key.json

# Web App authentication
# Used by Node.js server to sign JWT tokens after web login.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# ESP32 authentication
# ESP32 should send this token when connecting to WebSocket.
ESP32_DEVICE_ID=esp32-main
ESP32_DEVICE_TOKEN=change_this_esp32_device_token

# Optional timezone used for access time-window logic and logs
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Optional Firebase project id, only needed if you want to reference it in code/logs
FIREBASE_PROJECT_ID=smart-home-esp32
